# Database
DATABASE_URL=postgresql+psycopg://cmpys:cmpys@localhost:5432/cmpys
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-random-production-secret
HTTP_BODY_LOGGING_ENABLED=false

# LLM
LLM_PROVIDER=yunwu
YUNWU_API_KEY=your-yunwu-api-key
YUNWU_BASE_URL=https://yunwu.ai/v1
YUNWU_FAST_MODEL=gpt-5.6-luna
YUNWU_MODEL=grok-4.5
YUNWU_QUALITY_MODEL=claude-fable-5
YUNWU_FALLBACK_ENABLED=true
# Set to 1 only for a token assigned to Yunwu's default group.
YUNWU_GROUP_RATIO=6
YUNWU_QUOTA_PRICE_CNY=0.5
YUNWU_USD_EXCHANGE_RATE=7.3

# Retained for native Google Search grounding and provider fallback.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_QUALITY_MODEL=gemini-3.1-pro-preview
TAVILY_API_KEY=your-tavily-api-key

# Background catalog budget / throughput
CATALOG_SCHEDULER_ENABLED=true
CATALOG_DISPATCH_PER_TICK=2
CATALOG_WORKER_CONCURRENCY=2
CATALOG_DAILY_JOB_LIMIT=50
CATALOG_MAX_ATTEMPTS=3
CATALOG_QUOTES_PER_IDOL_LIMIT=30
CATALOG_QUOTE_MIN_CONFIDENCE=0.84
CATALOG_QUOTE_VERIFICATION_ENABLED=true
CATALOG_QUOTE_VERIFICATION_BATCH_SIZE=4
CATALOG_QUOTE_VERIFICATION_DAILY_LIMIT=2
CATALOG_IDLE_DISCOVERY_ENABLED=true
CATALOG_IDLE_DISCOVERY_INTERVAL_SECONDS=900
CATALOG_IDLE_DISCOVERY_DAILY_LIMIT=6
CATALOG_IDLE_DISCOVERY_RECENT_USER_MINUTES=10
CATALOG_IDLE_DISCOVERY_PRIORITY=10
CATALOG_IDLE_DISCOVERY_INTERACTIVE_QUEUES=high_priority,default,low_priority
LLM_USAGE_TELEMETRY_ENABLED=true
LLM_BACKGROUND_DAILY_BUDGET_USD=0.50
LLM_BACKGROUND_BUDGET_SOFT_RATIO=0.85
LLM_BUDGET_INCLUDE_SEARCH_OVERAGE=false
CATALOG_BOOK_BUDGET_RESERVE_USD=0.06
CATALOG_IDOL_BUDGET_RESERVE_USD=0.12
CATALOG_QUOTE_VERIFICATION_BUDGET_RESERVE_USD=0.04
ADAPTIVE_ROUTING_ENABLED=true
ADAPTIVE_ROUTING_LOOKBACK_DAYS=30
ADAPTIVE_ROUTING_MIN_SAMPLES=20
ADAPTIVE_ROUTING_CANARY_PERCENT=10
ADAPTIVE_ROUTING_MIN_SUCCESS_RATE=0.90
ADAPTIVE_ROUTING_MIN_QUALITY_SCORE=0.90

# Optional: OpenAI fallback
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini

# Plan generation
PLAN_GENERATOR_MODE=llm
